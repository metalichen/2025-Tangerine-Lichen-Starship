geom_tile(aes(fill = taxonPrevalence, color=ifelse(p_val_BH<=0.05, '#ff264e', 'NA'), alpha=ifelse(p_val_BH<=0.05, 0, 1)), linewidth = 1) +
geom_tile(aes(fill = taxonPrevalence, color=ifelse(p_val_BH<=0.05, '#ff264e', 'NA'), alpha=ifelse(p_val_BH<=0.05, 1, 0)), linewidth = 1) +
scale_color_identity() +
coord_equal() +
guides(alpha=”none”) +
